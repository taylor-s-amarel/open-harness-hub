{
  "@context": {
    "@version": 1.1,
    "schema":  "https://schema.org/",
    "ohh":     "https://open-harness-hub.dev/ns/",
    "dcat":    "http://www.w3.org/ns/dcat#",
    "dcterms": "http://purl.org/dc/terms/",
    "skos":    "http://www.w3.org/2004/02/skos/core#",
    "prov":    "http://www.w3.org/ns/prov#",
    "odrl":    "http://www.w3.org/ns/odrl/2/",
    "dpv":     "https://w3id.org/dpv#",
    "spdx":    "http://spdx.org/rdf/terms#",
    "cr":      "http://mlcommons.org/croissant/",
    "sc":      "https://schema.org/",
    "mcp":     "https://modelcontextprotocol.io/ns/",
    "ai":      "https://open-harness-hub.dev/ns/ai/",

    "Harness":       "ohh:Harness",
    "Pipeline":      "ohh:Pipeline",
    "RulePack":      "ohh:RulePack",
    "KnowledgePack": "ohh:KnowledgePack",
    "LogicPack":     "ohh:LogicPack",
    "Tool":          "ohh:Tool",
    "Processor":     "ohh:Processor",
    "Persona":       "ohh:Persona",
    "Adapter":       "ohh:Adapter",
    "Rubric":        "ohh:Rubric",
    "Benchmark":     "ohh:Benchmark",

    "id":           "@id",
    "type":         "@type",
    "name":         "schema:name",
    "description":  "schema:description",
    "version":      "schema:softwareVersion",
    "license":      "schema:license",
    "authors":      "schema:author",
    "links":        "schema:url",
    "tags":         "schema:keywords",
    "created":      "schema:dateCreated",
    "updated":      "schema:dateModified",

    "industry":     { "@id": "ohh:industry",   "@container": "@set" },
    "capability":   { "@id": "ohh:capability", "@container": "@set" },
    "modality":     { "@id": "ohh:modality",   "@container": "@set" },
    "lifecycle":    "ohh:lifecycleMaturity",
    "lifecycle_position": "ohh:lifecyclePosition",
    "trust_boundary":     "ohh:trustBoundary",
    "freshness":          "ohh:freshness",
    "pipeline_kind":      "ohh:pipelineKind",
    "process_kind":       "ohh:processKind",
    "applied_layers":     { "@id": "ohh:appliedLayer", "@container": "@set" },
    "consumes":           { "@id": "ohh:consumes",      "@container": "@set" },
    "emits":              { "@id": "ohh:emits",         "@container": "@set" },
    "step_refs":          { "@id": "ohh:stepRef",       "@container": "@list" },
    "logic_paths":        "ohh:logicPath",
    "model_targets":      "ohh:modelTarget",
    "knowledge_packs":    "ohh:knowledgePackRef",
    "logic_packs":        "ohh:logicPackRef",
    "model_io":           "ohh:modelIO",
    "input_verification": "ohh:inputVerification",
    "output_verification": "ohh:outputVerification",

    "attribution":   { "@id": "prov:wasAttributedTo" },
    "provenance":    "prov:wasDerivedFrom",
    "reproducibility": "ohh:reproducibility",

    "privacy_boundaries": {
      "@id": "ohh:privacyBoundaries",
      "@context": {
        "data_categories":              { "@id": "dpv:hasPersonalDataCategory", "@type": "@id" },
        "hipaa_safe_harbor_categories": { "@id": "ohh:hipaaSafeHarborCategory", "@type": "@id" },
        "purposes":                     { "@id": "dpv:hasPurpose",              "@type": "@id" },
        "legal_basis":                  { "@id": "dpv:hasLegalBasis",           "@type": "@id" },
        "raw_input":                    "ohh:rawInputBoundary",
        "derived_output":               "ohh:derivedOutputBoundary",
        "external_calls":               "ohh:externalCallsPolicy"
      }
    },

    "eu_ai_act_risk":      "ohh:euAIActRisk",
    "nist_ai_rmf_controls": { "@id": "ohh:nistAIRmfControl", "@container": "@set" },
    "iso_42001_controls":   { "@id": "ohh:iso42001Control",  "@container": "@set" }
  }
}
