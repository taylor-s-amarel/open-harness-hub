{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sha256_hash output",
  "type": "object",
  "required": ["sha256", "byte_count"],
  "properties": {
    "sha256":     { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "byte_count": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
