{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "normalize_date output",
  "type": "object",
  "required": ["input", "iso8601", "ok"],
  "properties": {
    "input":   { "type": "string" },
    "iso8601": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "ok":      { "type": "boolean" }
  },
  "additionalProperties": false
}
