{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-harness-hub.dev/schemas/knowledge-pack.schema.json",
  "title": "Knowledge pack manifest",
  "allOf": [
    { "$ref": "_common.schema.json#/$defs/envelope" },
    {
      "type": "object",
      "required": ["content_types"],
      "properties": {
        "type":          { "const": "knowledge-pack" },
        "content_types": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path":   { "type": "string" },
              "schema": { "type": "string" },
              "format": { "type": "string", "enum": ["jsonl", "yaml", "csv", "md", "json", "txt"] }
            }
          }
        },
        "indexing": {
          "type": "object",
          "properties": {
            "bm25":  { "type": "boolean" },
            "dense": { "type": "object" }
          }
        },
        "provenance": {
          "type": "object",
          "properties": {
            "sources":           { "type": "array", "items": { "type": "string" } },
            "collected_through": { "type": "string", "format": "date" },
            "collected_by":      { "type": "string" },
            "anonymization":     { "type": "string" }
          }
        }
      }
    }
  ]
}
