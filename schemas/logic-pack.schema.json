{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-harness-hub.dev/schemas/logic-pack.schema.json",
  "title": "Logic pack manifest",
  "description": "Non-data packs: prompts, schemas, response policies, tool registries.",
  "allOf": [
    { "$ref": "_common.schema.json#/$defs/envelope" },
    {
      "type": "object",
      "required": ["content_types"],
      "properties": {
        "type":          { "const": "logic-pack" },
        "content_types": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path":   { "type": "string" },
              "schema": { "type": "string" },
              "format": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
